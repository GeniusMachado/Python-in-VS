// © tradeforopp — Upgraded: DR/IDR Case Study [TFO] (v6) - FIXED VERSION
// SPDX-License-Identifier: MPL-2.0
//@version=6
indicator("DR/IDR Case Study [TFO] Fixed", shorttitle="DRv2-Fixed", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=200)

// -------------------- INPUTS --------------------
g_input = "Main"
timeframe_input = input.timeframe("5", "DR Timeframe", tooltip="Timeframe used to define DR/IDR (NY local time)", group=g_input)
session_choice   = input.string("NY (09:30-10:30)", "DR Session Preset", options=["NY (09:30-10:30)","London (03:00-04:00)","Asia (21:00-22:00)","Custom"], group=g_input)
custom_session   = input.session("0930-1030", "Custom Session (if chosen)", group=g_input)
session_ext      = input.session("1030-1600", "Extension Session", tooltip="NY local time window for tracking outcomes", group=g_input)

break_logic      = input.string("Wick", "Break Logic", options=["Wick","Close","Body"], group=g_input)
track_rolling_n  = input.int(20, "Rolling N sessions (for last N %)", minval=1, group=g_input)

enable_alerts    = input.bool(true, "Enable default alertconditions (turn on/off)", group=g_input)
compact_markers  = input.bool(true, "Use compact markers instead of large labels", group=g_input)
show_box         = input.bool(true, "Show DR body box", group=g_input)
box_opacity      = input.int(70, "DR box opacity (0-100)", minval=0, maxval=100, group=g_input)

strategy_mode    = input.bool(false, "Enable Strategy Backtest Mode (requires strategy script)", group=g_input)
risk_rr          = input.float(1.0, "Target (x DR)", minval=0.1, step=0.1, group=g_input)
risk_rr2         = input.float(2.0, "Target 2 (x DR)", minval=0.1, step=0.1, group=g_input)

visuals          = "Visuals"
dr_color_input   = input.color(color.gray, "DR Color", group=visuals)
idr_color_input  = input.color(color.green, "IDR Color", group=visuals)
fade_after_ext   = input.int(60, "Fade lines after extension (bars)", minval=0, group=visuals)

multi_tf_overlay = input.bool(true, "Show DR from another timeframe for confluence", group=visuals)
overlay_tf       = input.timeframe("15", "Overlay timeframe (if enabled)", group=visuals)

stats_group = "Statistics"
table_position_input = input.string('Top Right', "Table Position", options = ['Bottom Center', 'Bottom Left', 'Bottom Right', 'Middle Center', 'Middle Left', 'Middle Right', 'Top Center', 'Top Left', 'Top Right'], group=stats_group)

// -------------------- TABLE POSITION MAPPING --------------------
table_position = switch table_position_input
    "Bottom Center" => position.bottom_center
    "Bottom Left"   => position.bottom_left
    "Bottom Right"  => position.bottom_right
    "Middle Center" => position.middle_center
    "Middle Left"   => position.middle_left
    "Middle Right"  => position.middle_right
    "Top Center"    => position.top_center
    "Top Left"      => position.top_left
    "Top Right"     => position.top_right

// -------------------- HELPERS --------------------
f_session_from_choice(choice, custom) =>
    if choice == "NY (09:30-10:30)"
        "0930-1030"
    else if choice == "London (03:00-04:00)"
        "0300-0400"
    else if choice == "Asia (21:00-22:00)"
        "2100-2200"
    else
        custom

session = f_session_from_choice(session_choice, custom_session)

// session booleans (based on DR timeframe)
dr_time_tf     = not na(time(timeframe_input, session, "America/New_York"))
dr_ext_time_tf = not na(time(timeframe_input, session_ext, "America/New_York"))

// request security for DR timeframe and overlay TF
[dr_tf_open, dr_tf_high, dr_tf_low, dr_tf_close] = request.security(syminfo.tickerid, timeframe_input, [open, high, low, close], barmerge.gaps_off, barmerge.lookahead_on)
[overlay_open, overlay_high, overlay_low, overlay_close] = request.security(syminfo.tickerid, overlay_tf, [open, high, low, close], barmerge.gaps_off, barmerge.lookahead_on)

// -------------------- STATE --------------------
varip float dr_high = na
varip float dr_low  = na
varip float idr_high = na
varip float idr_low  = na
varip bool dr_active = false
varip bool dr_broken = false
varip int bars_since_ext_end = 0

var int total_sessions = 0
var int total_held     = 0
var int total_drh_success = 0
var int total_drl_success = 0

var float[] recent_results = array.new_float()
var string[] recent_labels = array.new_string()
var float[] recent_ranges = array.new_float()

var line drh_line = na
var line drl_line = na
var line idrh_line = na
var line idrl_line = na
var box  dr_box = na
var line proj1h = na
var line proj1l = na
var line proj2h = na
var line proj2l = na

var label break_marker = na
var label result_marker = na

// ---------- helper object functions ----------
f_new_or_set_line(line l, int x1, float y1, int x2, float y2, color col, style, int width) =>
    if na(l)
        lnew = line.new(x1, y1, x2, y2, xloc.bar_index, extend=extend.right, color=col, style=style, width=width)
        lnew
    else
        line.set_xy1(l, x1, y1)
        line.set_xy2(l, x2, y2)
        line.set_color(l, col)
        line.set_style(l, style)
        line.set_width(l, width)
        l

f_new_or_set_box(box b, int x1, float y1, int x2, float y2, color bgcolor) =>
    if na(b)
        bnew = box.new(x1, y1, x2, y2, border_color = bgcolor, bgcolor = bgcolor)
        bnew
    else
        box.set_left(b, x1)
        box.set_right(b, x2)
        box.set_top(b, y1)
        box.set_bottom(b, y2)
        box.set_bgcolor(b, bgcolor)
        box.set_border_color(b, bgcolor)
        b

f_marker_create_or_move(label lbl, int x, float y, string txt, style, color col) =>
    if na(lbl)
        lnew = label.new(x, y, txt, xloc.bar_index, yloc.price, style=style, color=col, textcolor=color.white, size=size.small)
        lnew
    else
        label.set_xy(lbl, x, y)
        label.set_text(lbl, txt)
        label.set_style(lbl, style)
        label.set_color(lbl, col)
        lbl

// -------------------- DR SESSION START --------------------
is_new_dr_start = dr_time_tf and not dr_time_tf[1]
if is_new_dr_start
    dr_active := true
    dr_broken := false
    bars_since_ext_end := 0

    dr_high := dr_tf_high
    dr_low  := dr_tf_low
    idr_high := math.max(dr_tf_open, dr_tf_close)
    idr_low  := math.min(dr_tf_open, dr_tf_close)

    // baseline lines/box
    drh_line := f_new_or_set_line(drh_line, bar_index, dr_high, bar_index + 1, dr_high, dr_color_input, line.style_solid, 2)
    drl_line := f_new_or_set_line(drl_line, bar_index, dr_low,  bar_index + 1, dr_low,  dr_color_input, line.style_solid, 2)
    idrh_line := f_new_or_set_line(idrh_line, bar_index, idr_high, bar_index + 1, idr_high, idr_color_input, line.style_dashed, 1)
    idrl_line := f_new_or_set_line(idrl_line, bar_index, idr_low,  bar_index + 1, idr_low,  idr_color_input, line.style_dashed, 1)

    if show_box
        dr_box := f_new_or_set_box(dr_box, bar_index, idr_high, bar_index + 1, idr_low, color.new(color.gray, box_opacity))

    // projection placeholders
    proj1h := f_new_or_set_line(proj1h, bar_index, na, bar_index + 1, na, color.new(color.orange, 0), line.style_dashed, 1)
    proj1l := f_new_or_set_line(proj1l, bar_index, na, bar_index + 1, na, color.new(color.orange, 0), line.style_dashed, 1)
    proj2h := f_new_or_set_line(proj2h, bar_index, na, bar_index + 1, na, color.new(color.orange, 20), line.style_dotted, 1)
    proj2l := f_new_or_set_line(proj2l, bar_index, na, bar_index + 1, na, color.new(color.orange, 20), line.style_dotted, 1)

// -------------------- DURING DR SESSION --------------------
if dr_active
    dr_high := math.max(dr_high, dr_tf_high)
    dr_low  := math.min(dr_low,  dr_tf_low)
    body_high = math.max(dr_tf_open, dr_tf_close)
    body_low  = math.min(dr_tf_open, dr_tf_close)
    idr_high := math.max(idr_high, body_high)
    idr_low  := math.min(idr_low,  body_low)

    x1h = na(drh_line) ? bar_index : line.get_x1(drh_line)
    x1l = na(drl_line) ? bar_index : line.get_x1(drl_line)
    x1ih = na(idrh_line) ? bar_index : line.get_x1(idrh_line)
    x1il = na(idrl_line) ? bar_index : line.get_x1(idrl_line)

    drh_line := f_new_or_set_line(drh_line, x1h, dr_high, bar_index + 1, dr_high, dr_color_input, line.style_solid, 2)
    drl_line := f_new_or_set_line(drl_line, x1l, dr_low,  bar_index + 1, dr_low,  dr_color_input, line.style_solid, 2)
    idrh_line := f_new_or_set_line(idrh_line, x1ih, idr_high, bar_index + 1, idr_high, idr_color_input, line.style_dashed, 1)
    idrl_line := f_new_or_set_line(idrl_line, x1il, idr_low,  bar_index + 1, idr_low,  idr_color_input, line.style_dashed, 1)

    if show_box
        left_x = na(dr_box) ? bar_index : box.get_left(dr_box)
        dr_box := f_new_or_set_box(dr_box, left_x, idr_high, bar_index + 1, idr_low, color.new(color.gray, box_opacity))

// -------------------- EXTENSION & BREAK DETECTION --------------------
is_in_extension = dr_ext_time_tf
break_high = false
break_low  = false

if is_in_extension and not dr_broken and not na(dr_high)
    if break_logic == "Wick"
        if dr_tf_high > dr_high
            break_high := true
        if dr_tf_low < dr_low
            break_low := true
    else if break_logic == "Close"
        if dr_tf_close > dr_high
            break_high := true
        if dr_tf_close < dr_low
            break_low := true
    else
        b_high = math.max(dr_tf_open, dr_tf_close)
        b_low  = math.min(dr_tf_open, dr_tf_close)
        if b_high > dr_high
            break_high := true
        if b_low < dr_low
            break_low := true

if (break_high or break_low) and dr_active and not dr_broken
    dr_broken := true
    if compact_markers
        break_marker := f_marker_create_or_move(break_marker, bar_index, break_high ? dr_high : dr_low, break_high ? "↑BRK" : "↓BRK", label.style_label_up, color.new(color.blue, 0))
    else
        break_marker := f_marker_create_or_move(break_marker, bar_index, break_high ? dr_high : dr_low, break_high ? "Close Through DRH" : "Close Through DRL", label.style_label_down, color.blue)

// -------------------- AFTER EXTENSION ENDS -> evaluate Held/Not Held --------------------
was_in_ext_prev = dr_ext_time_tf[1]
is_ext_now = dr_ext_time_tf
ext_just_ended = was_in_ext_prev and not is_ext_now and dr_active

if ext_just_ended
    held = not dr_broken
    total_sessions += 1
    if held
        total_held += 1

    // Track success rates for break scenarios
    if dr_broken
        if break_high
            // After high break, check if price came back below DR low (successful retest)
            if close < dr_low
                total_drl_success += 1
        if break_low
            // After low break, check if price came back above DR high (successful retest)
            if close > dr_high
                total_drh_success += 1

    array.unshift(recent_results, held ? 1.0 : 0.0)
    array.unshift(recent_labels, held ? "H" : "N")
    array.unshift(recent_ranges, dr_high - dr_low)
    while array.size(recent_results) > track_rolling_n
        array.pop(recent_results)
        array.pop(recent_labels)
        array.pop(recent_ranges)

    mid = (idr_high + idr_low) / 2
    result_marker := f_marker_create_or_move(result_marker, bar_index, mid, held ? "HELD" : "NOT", label.style_label_left, held ? color.new(color.green, 20) : color.new(color.red, 10))

    dr_active := false
    bars_since_ext_end := 0

// -------------------- FADE AFTER END --------------------
if not dr_active and not na(drh_line)
    bars_since_ext_end += 1
    fade_percent = fade_after_ext > 0 ? math.min(100, math.round(100 * bars_since_ext_end / float(fade_after_ext))) : 0
    line.set_color(drh_line, color.new(dr_color_input, fade_percent))
    line.set_color(drl_line, color.new(dr_color_input, fade_percent))
    line.set_color(idrh_line, color.new(idr_color_input, fade_percent))
    line.set_color(idrl_line, color.new(idr_color_input, fade_percent))
    if show_box
        box.set_bgcolor(dr_box, color.new(color.gray, math.min(100, box_opacity + fade_percent)))

// -------------------- PROJECTIONS (RR1/RR2) --------------------
if not na(dr_high) and not na(dr_low)
    dr_range = dr_high - dr_low
    if dr_range > 0
        x1h = na(drh_line) ? bar_index : line.get_x1(drh_line)
        x1l = na(drl_line) ? bar_index : line.get_x1(drl_line)
        proj1h := f_new_or_set_line(proj1h, x1h, dr_high + dr_range * risk_rr, bar_index + 1, dr_high + dr_range * risk_rr, color.new(color.orange, 0), line.style_dashed, 1)
        proj1l := f_new_or_set_line(proj1l, x1l, dr_low  - dr_range * risk_rr, bar_index + 1, dr_low  - dr_range * risk_rr, color.new(color.orange, 0), line.style_dashed, 1)
        proj2h := f_new_or_set_line(proj2h, x1h, dr_high + dr_range * risk_rr2, bar_index + 1, dr_high + dr_range * risk_rr2, color.new(color.orange, 30), line.style_dotted, 1)
        proj2l := f_new_or_set_line(proj2l, x1l, dr_low  - dr_range * risk_rr2, bar_index + 1, dr_low  - dr_range * risk_rr2, color.new(color.orange, 30), line.style_dotted, 1)

// -------------------- MULTI-TF OVERLAY --------------------
if multi_tf_overlay
    var line ov_high_line = na
    var line ov_low_line  = na
    ov_high_line := f_new_or_set_line(ov_high_line, bar_index, overlay_high, bar_index + 1, overlay_high, color.new(color.blue, 80), line.style_dotted, 1)
    ov_low_line  := f_new_or_set_line(ov_low_line,  bar_index, overlay_low,  bar_index + 1, overlay_low,  color.new(color.blue, 80), line.style_dotted, 1)

// -------------------- ALERTS --------------------
alertcondition(enable_alerts and break_high, title="DRH Broken", message="{{ticker}} DRH broken at {{time}}")
alertcondition(enable_alerts and break_low,  title="DRL Broken", message="{{ticker}} DRL broken at {{time}}")
alertcondition(enable_alerts and ext_just_ended and not dr_broken, title="DR Held", message="{{ticker}} DR held for session ending {{time}}")
alertcondition(enable_alerts and ext_just_ended and dr_broken,     title="DR Not Held", message="{{ticker}} DR NOT held for session ending {{time}}")

// -------------------- HELPER FUNCTIONS --------------------
fmt(x) =>
    na(x) ? "—" : str.tostring(x, "#.0")

// -------------------- STATS TABLE --------------------
var table stats_tbl = table.new(table_position, 4, 6, border_color=color.gray, frame_color=color.gray)
if barstate.islast
    rolling_count = array.size(recent_results)
    rolling_sum = 0.0
    for i = 0 to array.size(recent_results) - 1
        rolling_sum += array.get(recent_results, i)
    rolling_pct = rolling_count > 0 ? (rolling_sum / rolling_count * 100) : na

    overall_pct = total_sessions > 0 ? (total_held / total_sessions * 100) : na
    drh_pct     = total_sessions > 0 ? (total_drh_success / total_sessions * 100) : na
    drl_pct     = total_sessions > 0 ? (total_drl_success / total_sessions * 100) : na
    
    table.cell(stats_tbl, 0, 0, "Total Sessions", bgcolor=color.new(color.white, 90))
    table.cell(stats_tbl, 1, 0, str.tostring(total_sessions), bgcolor=color.new(color.white, 90))
    table.cell(stats_tbl, 0, 1, "Overall Held %", bgcolor = color.new(color.white, 80))
    table.cell(stats_tbl, 1, 1, fmt(overall_pct) + "%", bgcolor = (na(overall_pct) ? color.new(color.white,80) : (overall_pct >= 60 ? color.new(color.green, 80) : color.new(color.red, 80))))
    table.cell(stats_tbl, 0, 2, "Rolling (" + str.tostring(track_rolling_n) + ")", bgcolor=color.new(color.white, 80))
    table.cell(stats_tbl, 1, 2, fmt(rolling_pct) + "%", bgcolor = (na(rolling_pct) ? color.new(color.white,80) : (rolling_pct >= 60 ? color.new(color.green, 80) : color.new(color.red, 80))))
    table.cell(stats_tbl, 0, 3, "DRH Success %", bgcolor=color.new(color.white, 90))
    table.cell(stats_tbl, 1, 3, fmt(drh_pct) + "%", bgcolor = (na(drh_pct) ? color.new(color.white,90) : (drh_pct >= 60 ? color.new(color.green, 80) : color.new(color.red, 80))))
    table.cell(stats_tbl, 0, 4, "DRL Success %", bgcolor=color.new(color.white, 90))
    table.cell(stats_tbl, 1, 4, fmt(drl_pct) + "%", bgcolor = (na(drl_pct) ? color.new(color.white,90) : (drl_pct >= 60 ? color.new(color.green, 80) : color.new(color.red, 80))))
    table.cell(stats_tbl, 0, 5, "Last Range (avg)", bgcolor=color.new(color.white, 90))
    avg_range = array.size(recent_ranges) > 0 ? (array.sum(recent_ranges) / array.size(recent_ranges)) : na
    table.cell(stats_tbl, 1, 5, na(avg_range) ? "—" : str.tostring(avg_range, "#.##"), bgcolor=color.new(color.white, 90))
    
    // Add debug information
    table.cell(stats_tbl, 2, 0, "Debug Info", bgcolor=color.new(color.yellow, 80))
    table.cell(stats_tbl, 3, 0, "Held: " + str.tostring(total_held), bgcolor=color.new(color.yellow, 80))
    table.cell(stats_tbl, 2, 1, "Broken: " + str.tostring(total_sessions - total_held), bgcolor=color.new(color.yellow, 80))
    table.cell(stats_tbl, 3, 1, "DRH: " + str.tostring(total_drh_success), bgcolor=color.new(color.yellow, 80))
    table.cell(stats_tbl, 2, 2, "DRL: " + str.tostring(total_drl_success), bgcolor=color.new(color.yellow, 80))
    table.cell(stats_tbl, 3, 2, "Active: " + str.tostring(dr_active), bgcolor=color.new(color.yellow, 80))
